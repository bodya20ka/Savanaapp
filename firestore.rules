rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
                    && incoming().keys().hasAll(['uid', 'username', 'displayName'])
                    && incoming().uid == request.auth.uid;
      allow update: if isOwner(userId)
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'lastSeen', 'status']);
    }

    // --- Chats Collection ---
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        existing().type == 'channel' ||
        request.auth.uid in existing().members
      );
      
      allow create: if isSignedIn() 
                    && incoming().members.size() >= 1
                    && request.auth.uid in incoming().members;

      allow update: if isSignedIn() 
                    && request.auth.uid in existing().members
                    && incoming().members.size() >= 1; // Basic membership check

      // --- Messages Subcollection ---
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.type == 'channel' ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
        );

        allow create: if isSignedIn()
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
                      && incoming().senderId == request.auth.uid
                      && incoming().content.size() <= 10000;

        allow update: if isSignedIn()
                      && (
                        (existing().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'edited', 'deleted', 'reactions'])) ||
                        (incoming().diff(existing()).affectedKeys().hasOnly(['reactions'])) // Others can react
                      );
      }
    }
  }
}
